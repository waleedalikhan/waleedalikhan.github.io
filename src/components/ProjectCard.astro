---
import type { Project } from "../data/projects";
import Icon from "./Icon.astro";

export interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;

/**
 * Span mapping into CSS grid:
 * sm → 1 col, 1 row
 * md → 1 col, 1 row (taller on desktop)
 * lg → 2 col wide on desktop
 * xl → 2 col wide + 2 row tall (hero tile)
 */
const spanClass: Record<Project["span"], string> = {
  sm: "lg:col-span-4 lg:row-span-1 md:min-h-[280px]",
  md: "lg:col-span-4 lg:row-span-1 md:min-h-[320px]",
  lg: "lg:col-span-8 lg:row-span-1 md:min-h-[320px]",
  xl: "lg:col-span-8 lg:row-span-2 md:min-h-[320px]",
};

const imageFrameClass: Record<Project["span"], string> = {
  sm: "aspect-[16/10]",
  md: "aspect-[16/10]",
  lg: "aspect-[16/10]",
  xl: "",
};

const isXlHero = project.span === "xl";

const tagList = project.tags.join(",");
---

<a
  href={project.href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "bento group flex flex-col gap-6 p-6 sm:p-7",
    spanClass[project.span],
    project.className,
  ]}
  data-project-card
  data-tags={tagList}
  data-reveal
  data-reveal-delay={index * 60}
  aria-label={`${project.title} — ${project.kicker}`}
>
  {/* --- Header row --- */}
  <header class="flex items-start justify-between gap-4">
    <div class="flex flex-col gap-1.5">
      <p
        class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-[color:var(--color-ink-mute)]"
      >
        {project.kicker}
      </p>
      <h3
        class="text-2xl font-semibold tracking-tight text-[color:var(--color-ink)] sm:text-3xl"
      >
        {project.title}
      </h3>
    </div>
    <span
      class="grid size-10 shrink-0 place-items-center rounded-full border border-[color:var(--color-hairline)] bg-[color:var(--color-obsidian)] text-[color:var(--color-ink-dim)] transition-all duration-400 group-hover:-translate-y-0.5 group-hover:border-[color:var(--color-lime)] group-hover:text-[color:var(--color-lime)]"
      aria-hidden="true"
    >
      <Icon name="arrow-up-right" size={16} />
    </span>
  </header>

  {
    !isXlHero && (
      <div
        class:list={[
          "relative w-full shrink-0 overflow-hidden rounded-xl border border-[color:var(--color-hairline)] bg-[color:var(--color-obsidian-raised)]",
          imageFrameClass[project.span],
        ]}
      >
        <img
          src={project.image}
          alt={`${project.title} — interface preview`}
          class="size-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    )
  }

  {/* --- Summary --- */}
  <p
    class:list={[
      "leading-relaxed text-[color:var(--color-ink-dim)]",
      project.span === "xl" ? "text-lg max-w-xl" : "text-base",
    ]}
  >
    {project.summary}
  </p>

  {/* --- Metric (if featured/xl) --- */}
  {
    project.metric && (
      <div class="flex items-baseline gap-3 border-t border-[color:var(--color-hairline)] pt-5">
        <span class="text-3xl font-semibold tracking-tight text-[color:var(--color-lime)] sm:text-4xl">
          {project.metric.value}
        </span>
        <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-[color:var(--color-ink-mute)]">
          {project.metric.label}
        </span>
      </div>
    )
  }

  {
    isXlHero && (
      <div class="relative aspect-[16/10] w-full max-h-[15rem] shrink-0 overflow-hidden rounded-xl border border-[color:var(--color-hairline)] bg-[color:var(--color-obsidian-raised)] sm:max-h-[17rem] lg:aspect-[2/1] lg:max-h-[min(36vw,18rem)]">
        <img
          src={project.image}
          alt={`${project.title} — interface preview`}
          class="absolute inset-0 size-full object-cover object-[50%_28%]"
          loading="lazy"
          decoding="async"
        />
      </div>
    )
  }

  {/* --- Footer --- */}
  <footer
    class="mt-auto flex flex-wrap items-center justify-between gap-3 pt-2"
  >
    <div class="flex flex-wrap gap-1.5">
      {
        project.stack
          .slice(0, 4)
          .map((tech) => (
            <span class="rounded-full border border-[color:var(--color-hairline)] bg-[color:var(--color-obsidian)] px-2.5 py-1 font-mono text-[0.7rem] text-[color:var(--color-ink-dim)]">
              {tech}
            </span>
          ))
      }
    </div>
    <span
      class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-[color:var(--color-ink-mute)]"
    >
      {project.role}
    </span>
  </footer>
</a>

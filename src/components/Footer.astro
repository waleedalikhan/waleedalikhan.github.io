---
import { site, socials } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="relative border-t border-[color:var(--color-hairline)]">
	<div class="container-frame py-10">
		<div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
			<p class="font-mono text-xs uppercase tracking-[0.14em] text-[color:var(--color-ink-mute)]">
				© {year} {site.name}. Crafted with Astro + Tailwind v4.
			</p>
			<div class="flex items-center gap-5 text-xs text-[color:var(--color-ink-dim)]">
				<a
					href={socials.github}
					target="_blank"
					rel="noopener noreferrer"
					class="transition-colors hover:text-[color:var(--color-ink)]"
				>
					GitHub
				</a>
				<a
					href={socials.linkedin}
					target="_blank"
					rel="noopener noreferrer"
					class="transition-colors hover:text-[color:var(--color-ink)]"
				>
					LinkedIn
				</a>
				<a
					href={socials.email}
					class="transition-colors hover:text-[color:var(--color-ink)]"
				>
					Email
				</a>
				<a
					href="#top"
					class="transition-colors hover:text-[color:var(--color-ink)]"
					aria-label="Back to top"
				>
					↑ Top
				</a>
			</div>
		</div>
	</div>
</footer>
